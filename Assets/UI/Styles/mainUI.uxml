    <Style src="project://database/Assets/UI/Styles/styles.uss?fileID=7433441132597879392&amp;guid=24321227b73f9db4e8600d40e70c79cb&amp;type=3#styles"/>
    <ui:VisualElement name="VisualElement" style="flex-grow: initial; background-image: none; -unity-slice-scale: 0.5px; -unity-slice-left: 0; -unity-slice-top: 0; -unity-slice-right: 0; -unity-slice-bottom: 0; flex-shrink: 1; flex-wrap: nowrap; justify-content: center; align-self: center; width: 100%; aspect-ratio: auto; align-items: center; height: 100%; align-content: center; min-width: auto; max-height: none; max-width: none; top: auto; left: auto; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px;">
