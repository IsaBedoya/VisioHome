                <ui:TextField label="" placeholder-text="Código del apartamento" name="CodeInput" focusable="true" max-length="10" password="false" style="-unity-font-definition: url(&quot;project://database/Assets/Fonts/Orbitron-VariableFont_wght.ttf?fileID=12800000&amp;guid=0d149c3f2eedbc8438e035bf626aacfd&amp;type=3#Orbitron-VariableFont_wght&quot;); background-image: none; -unity-background-image-tint-color: rgba(157, 157, 246, 0); -unity-slice-scale: 0; background-color: rgba(157, 157, 246, 0); -unity-slice-left: 0; -unity-slice-top: 0; -unity-slice-right: 0; -unity-slice-bottom: 0; border-left-color: rgba(157, 157, 246, 0); border-right-color: rgba(157, 157, 246, 0); border-top-color: rgba(157, 157, 246, 0); border-bottom-color: rgba(157, 157, 246, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; border-bottom-left-radius: 0; border-bottom-right-radius: 0; border-top-right-radius: 0; border-top-left-radius: 0; -unity-background-scale-mode: stretch-to-fill; -unity-slice-type: tiled; -unity-text-auto-size: best-fit 5px 10px; -unity-text-generator: advanced; -unity-text-outline-color: rgba(0, 0, 0, 0); -unity-text-outline-width: 0; text-overflow: ellipsis; -unity-text-align: middle-left; color: rgba(157, 157, 246, 0); text-shadow: 0 0 10px rgba(0, 0, 0, 0); left: auto; right: auto; width: 100%; justify-content: center; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0;"/>
